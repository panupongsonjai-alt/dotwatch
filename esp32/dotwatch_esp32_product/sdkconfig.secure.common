# Shared hardware trust configuration for ESP32 revision v3.0+.
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_secure_ota.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions_secure_ota.csv"
CONFIG_PARTITION_TABLE_OFFSET=0x10000

CONFIG_SECURE_SIGNED_ON_BOOT=y
CONFIG_SECURE_SIGNED_ON_UPDATE=y
CONFIG_SECURE_SIGNED_APPS=y
CONFIG_SECURE_BOOT_V2_RSA_ENABLED=y
CONFIG_SECURE_SIGNED_APPS_RSA_SCHEME=y
CONFIG_SECURE_BOOT=y
CONFIG_SECURE_BOOT_V2_ENABLED=y
CONFIG_SECURE_BOOT_BUILD_SIGNED_BINARIES=y
CONFIG_SECURE_BOOT_FLASH_BOOTLOADER_DEFAULT=y

CONFIG_SECURE_FLASH_ENC_ENABLED=y
CONFIG_NVS_ENCRYPTION=y
CONFIG_NVS_SEC_KEY_PROTECT_USING_FLASH_ENC=y
CONFIG_BOOTLOADER_LOG_LEVEL_WARN=y
