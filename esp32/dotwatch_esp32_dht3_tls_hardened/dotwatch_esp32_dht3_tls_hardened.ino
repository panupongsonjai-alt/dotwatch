String defaultAdminPin() {
  String code = cfg.deviceCode;
  code.replace("-", "");
  code.replace("_", "");
  code.trim();

  if (code.length() >= 6) {
    return code.substring(code.length() - 6);
  }

  return "123456";
}

String effectiveAdminPin() {
  String pin = cfg.adminPin;
  pin.trim();

  if (pin.length() >= 4) return pin;

  return defaultAdminPin();
}

bool isAdminAuthorized() {
  if (portalMode) return true;

  if (!server.hasArg("pin")) return false;

  String provided = server.arg("pin");
  provided.trim();

  return provided == effectiveAdminPin();
}

String currentPinValue() {
  if (portalMode) return "";
  if (!server.hasArg("pin")) return "";
  return htmlEscape(server.arg("pin"));
}

String pinHiddenInput() {
  if (portalMode) return "";
  return "<input type='hidden' name='pin' value='" + currentPinValue() + "'>";
}

void sendLocalAdminLogin(int statusCode = 200, String message = "") {
  String body;
  body += "<section class='card'><h2>Local Admin Login</h2>";
  body += "<p class='muted'>ESP32 is online on your local Wi-Fi. Enter Local Admin PIN to edit Wi-Fi/backend/device settings.</p>";

  if (cfg.adminPin.length() == 0) {
    body += "<div class='notice'>ยังไม่ได้ตั้ง Custom PIN ค่าเริ่มต้นคือ 6 ตัวท้ายของ Device Code จนกว่าจะตั้ง PIN ใหม่ในหน้านี้</div>";
  }

  if (message.length() > 0) {
    body += "<div class='notice'>" + htmlEscape(message) + "</div>";
  }

  body += "<form method='GET' action='/'><div class='form'>";
  body += "<label class='full'>Local Admin PIN<input type='password' name='pin' inputmode='numeric' autocomplete='current-password' placeholder='Enter PIN'></label>";
  body += "</div><div class='row'><button type='submit'>Unlock</button><a class='btn btn2' href='/json'>Status JSON</a></div></form>";
  body += "</section>";

  server.send(statusCode, "text/html; charset=utf-8", pageShell("ESP32 Local Admin", body));
}

bool requireAdmin() {
  if (portalMode) return true;

  if (isAdminAuthorized()) return true;

  sendLocalAdminLogin(403, "PIN ไม่ถูกต้อง หรือยังไม่ได้กรอก PIN");
  return false;
}

void setupDht() {
  if (dht != nullptr) {
    delete dht;
    dht = nullptr;
  }

  dht = new DHT(cfg.dhtPin, cfg.dhtType);
  dht->begin();
}

void updateStatusLed() {
  if (portalMode) {
    blinkLed(250);
    return;
  }

  if (WiFi.status() != WL_CONNECTED) {
    blinkLed(1000);
    return;
  }

  if (lastSendStatus == "ok") {
    setLed(true);
    return;
  }

  blinkLed(500);
}

void checkResetButton() {
  bool pressed = digitalRead(RESET_BUTTON_PIN) == LOW;

  if (pressed && resetButtonPressedAt == 0) {
    resetButtonPressedAt = millis();
    Serial.println("Reset button pressed. Hold 6 seconds to clear config.");
  }

  if (!pressed) {
    resetButtonPressedAt = 0;
    return;
  }

  if (resetButtonPressedAt > 0 && millis() - resetButtonPressedAt >= RESET_HOLD_MS) {
    Serial.println("Reset button held. Clearing config and restarting.");
    clearConfig();
    delay(500);
    ESP.restart();
  }
}

void checkSelfRecovery() {
  unsigned long now = millis();

  if (WiFi.status() != WL_CONNECTED) {
    if (wifiDisconnectedSince == 0) wifiDisconnectedSince = now;

    if (!portalMode && now - wifiDisconnectedSince > WIFI_RESTART_AFTER_MS) {
      Serial.println("Wi-Fi disconnected too long. Restarting ESP32.");
      ESP.restart();
    }
    return;
  }

  wifiDisconnectedSince = 0;

  if (!portalMode && lastSuccessfulSendAt > 0 && now - lastSuccessfulSendAt > SEND_RESTART_AFTER_MS) {
    Serial.println("No successful send for too long. Restarting ESP32.");
    ESP.restart();
  }
}

bool connectWiFi() {
  if (WiFi.status() == WL_CONNECTED) return true;

  WiFiProfile profiles[WIFI_PROFILE_MAX];
  int profileCount = loadWiFiProfiles(profiles, WIFI_PROFILE_MAX);
  if (profileCount == 0) return false;

  WiFi.mode(portalMode ? WIFI_AP_STA : WIFI_STA);
  WiFi.setAutoReconnect(true);
  WiFi.setSleep(false);

  Serial.println("Scanning Wi-Fi for remembered networks...");
  int networkCount = WiFi.scanNetworks(false, true);
  if (networkCount > 0) {
    for (int i = 0; i < profileCount; i++) profiles[i].rssi = -999;

    for (int n = 0; n < networkCount; n++) {
      String foundSsid = WiFi.SSID(n);
      int foundRssi = WiFi.RSSI(n);
      for (int i = 0; i < profileCount; i++) {
        if (profiles[i].ssid == foundSsid && foundRssi > profiles[i].rssi) {
          profiles[i].rssi = foundRssi;
        }
      }
    }
  } else {
    Serial.println("Wi-Fi scan found no networks. Trying primary remembered network.");
  }

  int order[WIFI_PROFILE_MAX];
  int orderCount = 0;

  for (int i = 0; i < profileCount; i++) {
    if (networkCount <= 0 || profiles[i].rssi > -999 || profiles[i].primary) {
      order[orderCount++] = i;
    }
  }

  for (int a = 0; a < orderCount - 1; a++) {
    for (int b = a + 1; b < orderCount; b++) {
      int ia = order[a];
      int ib = order[b];
      bool swapNeeded = false;

      if (profiles[ib].rssi > profiles[ia].rssi) swapNeeded = true;
      if (profiles[ia].rssi == -999 && profiles[ib].rssi > -999) swapNeeded = true;
      if (!profiles[ia].primary && profiles[ib].primary && profiles[ia].rssi == profiles[ib].rssi) swapNeeded = true;

      if (swapNeeded) {
        int tmp = order[a];
        order[a] = order[b];
        order[b] = tmp;
      }
    }
  }

  unsigned long connectStarted = millis();
  bool connected = false;
  int connectedProfileIndex = -1;

  for (int oi = 0; oi < orderCount; oi++) {
    int profileIndex = order[oi];
    WiFiProfile &profile = profiles[profileIndex];

    if (millis() - connectStarted > WIFI_CONNECT_TOTAL_TIMEOUT_MS) {
      Serial.println("Wi-Fi connect total timeout.");
      break;
    }

    Serial.print("Connecting remembered Wi-Fi: ");
    Serial.print(profile.ssid);
    if (profile.rssi > -999) {
      Serial.print(" RSSI=");
      Serial.print(profile.rssi);
    }
    Serial.println();

    WiFi.disconnect(false, false);
    delay(150);
    WiFi.begin(profile.ssid.c_str(), profile.password.c_str());

    unsigned long attemptStarted = millis();
    while (WiFi.status() != WL_CONNECTED &&
           millis() - attemptStarted < WIFI_PROFILE_ATTEMPT_TIMEOUT_MS &&
           millis() - connectStarted < WIFI_CONNECT_TOTAL_TIMEOUT_MS) {
      checkResetButton();
      updateStatusLed();
      delay(500);
      Serial.print(".");
    }
    Serial.println();

    if (WiFi.status() == WL_CONNECTED) {
      connected = true;
      connectedProfileIndex = profileIndex;
      break;
    }

    Serial.println("Remembered Wi-Fi attempt failed. Trying next profile if available.");
  }

  WiFi.scanDelete();

  if (connected && connectedProfileIndex >= 0) {
    WiFiProfile &connectedProfile = profiles[connectedProfileIndex];
    persistConnectedWiFiProfile(connectedProfile);

    Serial.print("Wi-Fi connected. SSID=");
    Serial.print(WiFi.SSID());
    Serial.print(" IP=");
    Serial.println(WiFi.localIP());
    Serial.print("RSSI=");
    Serial.println(WiFi.RSSI());
    Serial.print("Remembered Wi-Fi profiles=");
    Serial.println(knownWiFiProfileCount());

    wifiDisconnectedSince = 0;
    return true;
  }

  Serial.println("Wi-Fi connect failed for all remembered networks.");
  return false;
}

void setupTime() {
  if (WiFi.status() != WL_CONNECTED) return;

  configTime(0, 0, "pool.ntp.org", "time.nist.gov", "time.google.com");

  Serial.print("NTP sync");
  for (int i = 0; i < 20; i++) {
    struct tm timeinfo;
    if (getLocalTime(&timeinfo, 500)) {
      Serial.println(" OK");
      return;
    }
    Serial.print(".");
  }
  Serial.println(" timeout");
}

String isoTimestampOrEmpty() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo, 20)) return "";

  char buffer[32];
  strftime(buffer, sizeof(buffer), "%Y-%m-%dT%H:%M:%SZ", &timeinfo);
  return String(buffer);
}

