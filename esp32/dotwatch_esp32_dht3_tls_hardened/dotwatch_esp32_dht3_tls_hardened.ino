String htmlEscape(String input) {
  input.replace("&", "&amp;");
  input.replace("<", "&lt;");
  input.replace(">", "&gt;");
  input.replace("\"", "&quot;");
  input.replace("'", "&#39;");
  return input;
}

String normalizeApiUrl(String value) {
  value.trim();
  while (value.endsWith("/")) value.remove(value.length() - 1);
  if (value.length() == 0) value = "https://dotwatch-backend.onrender.com";
  return value;
}

String maskSecret(const String &secret) {
  if (secret.length() == 0) return "Not set";
  if (secret.length() <= 8) return "********";
  return secret.substring(0, 4) + "********" + secret.substring(secret.length() - 4);
}

bool hasTlsCaCert() {
  return cfg.tlsCaCert.length() > 0;
}

bool hasEmbeddedTlsCaCert() {
  return strlen(DOTWATCH_EMBEDDED_ROOT_CA) > 0;
}

bool hasEffectiveTlsCaCert() {
  return hasTlsCaCert() || hasEmbeddedTlsCaCert();
}

const char *effectiveTlsCaCert() {
  if (hasTlsCaCert()) return cfg.tlsCaCert.c_str();
  return DOTWATCH_EMBEDDED_ROOT_CA;
}

String tlsCaCertSourceText() {
  if (hasTlsCaCert()) return "portal";
  if (hasEmbeddedTlsCaCert()) return "embedded";
  return "none";
}

String tlsModeText() {
  if (hasTlsCaCert()) {
    return "Root CA enabled (portal)";
  }

  if (hasEmbeddedTlsCaCert()) {
    return "Root CA enabled (embedded)";
  }

#if DOTWATCH_ALLOW_INSECURE_TLS_FALLBACK
  return "Insecure fallback enabled";
#else
  return "TLS CA required";
#endif
}

String uptimeText() {
  unsigned long sec = millis() / 1000;
  unsigned long days = sec / 86400;
  sec %= 86400;
  unsigned long hours = sec / 3600;
  sec %= 3600;
  unsigned long minutes = sec / 60;
  sec %= 60;

  String out = "";
  if (days > 0) out += String(days) + "d ";
  if (hours > 0 || days > 0) out += String(hours) + "h ";
  out += String(minutes) + "m " + String(sec) + "s";
  return out;
}

void setLed(bool on) {
  digitalWrite(STATUS_LED_PIN, on ? HIGH : LOW);
  ledState = on;
}

void blinkLed(unsigned long intervalMs) {
  if (millis() - lastLedBlinkAt >= intervalMs) {
    lastLedBlinkAt = millis();
    setLed(!ledState);
  }
}

void recordSendOk(int httpStatus) {
  lastHttpStatus = httpStatus;
  lastSendStatus = "ok";
  lastSendError = "";
  lastSuccessfulSendAt = millis();
  totalSendOk++;
}

void recordSendFail(int httpStatus, const String &error) {
  lastHttpStatus = httpStatus;
  lastSendStatus = "error";
  lastSendError = error;
  totalSendFail++;
}

void clearConfig() {
  prefs.begin("dotwatch", false);
  prefs.clear();
  prefs.end();
}

void loadConfig() {
  prefs.begin("dotwatch", true);
  cfg.wifiSsid = prefs.getString("wifiSsid", "");
  cfg.wifiPassword = prefs.getString("wifiPass", "");
  cfg.apiUrl = normalizeApiUrl(prefs.getString("apiUrl", "https://dotwatch-backend.onrender.com"));
  cfg.deviceCode = prefs.getString("devCode", "");
  cfg.deviceSecret = prefs.getString("devSecret", "");
  cfg.adminPin = prefs.getString("adminPin", "");
  cfg.tlsCaCert = prefs.getString("tlsCaCert", "");
  cfg.dhtPin = prefs.getInt("dhtPin", DEFAULT_DHT_PIN);
  cfg.dhtType = prefs.getInt("dhtType", DEFAULT_DHT_TYPE);
  cfg.sendIntervalMs = prefs.getULong("sendMs", DEFAULT_SEND_INTERVAL_MS);
  cfg.fallbackDummy = prefs.getBool("dummy", true);
  prefs.end();

  if (cfg.dhtPin < 0 || cfg.dhtPin > 39) cfg.dhtPin = DEFAULT_DHT_PIN;
  if (cfg.dhtType != DHT11 && cfg.dhtType != DHT22) cfg.dhtType = DEFAULT_DHT_TYPE;
  if (cfg.sendIntervalMs < MIN_SEND_INTERVAL_MS) cfg.sendIntervalMs = MIN_SEND_INTERVAL_MS;
}

void saveConfig(const Config &next) {
  prefs.begin("dotwatch", false);
  prefs.putString("wifiSsid", next.wifiSsid);
  prefs.putString("wifiPass", next.wifiPassword);
  prefs.putString("apiUrl", normalizeApiUrl(next.apiUrl));
  prefs.putString("devCode", next.deviceCode);
  prefs.putString("devSecret", next.deviceSecret);
  prefs.putString("adminPin", next.adminPin);
  prefs.putString("tlsCaCert", next.tlsCaCert);
  prefs.putInt("dhtPin", next.dhtPin);
  prefs.putInt("dhtType", next.dhtType);
  prefs.putULong("sendMs", next.sendIntervalMs);
  prefs.putBool("dummy", next.fallbackDummy);
  prefs.end();
}

int appendWiFiProfile(WiFiProfile profiles[], int count, String ssid, String password, bool primary = false) {
  ssid.trim();
  if (ssid.length() == 0) return count;

  for (int i = 0; i < count; i++) {
    if (profiles[i].ssid == ssid) {
      if (password.length() > 0 || profiles[i].password.length() == 0) {
        profiles[i].password = password;
      }
      profiles[i].primary = profiles[i].primary || primary;
      return count;
    }
  }

  if (count >= WIFI_PROFILE_MAX) return count;

  profiles[count].ssid = ssid;
  profiles[count].password = password;
  profiles[count].rssi = -999;
  profiles[count].primary = primary;
  return count + 1;
}

int loadWiFiProfiles(WiFiProfile profiles[], int maxProfiles) {
  int count = 0;

  if (cfg.wifiSsid.length() > 0) {
    count = appendWiFiProfile(profiles, count, cfg.wifiSsid, cfg.wifiPassword, true);
  }

  prefs.begin("dotwatch", true);
  String stored = prefs.getString(WIFI_PROFILES_KEY, "");
  prefs.end();

  if (stored.length() > 0) {
    StaticJsonDocument<1536> doc;
    DeserializationError error = deserializeJson(doc, stored);
    if (!error && doc.is<JsonArray>()) {
      JsonArray arr = doc.as<JsonArray>();
      for (JsonObject item : arr) {
        if (count >= maxProfiles) break;
        String ssid = item["s"] | "";
        String password = item["p"] | "";
        count = appendWiFiProfile(profiles, count, ssid, password, false);
      }
    }
  }

  return count;
}

void saveWiFiProfiles(WiFiProfile profiles[], int count) {
  StaticJsonDocument<1536> doc;
  JsonArray arr = doc.to<JsonArray>();

  for (int i = 0; i < count && i < WIFI_PROFILE_MAX; i++) {
    if (profiles[i].ssid.length() == 0) continue;
    JsonObject item = arr.createNestedObject();
    item["s"] = profiles[i].ssid;
    item["p"] = profiles[i].password;
  }

  String out;
  serializeJson(doc, out);

  prefs.begin("dotwatch", false);
  prefs.putString(WIFI_PROFILES_KEY, out);
  prefs.end();
}

void rememberWiFiProfile(String ssid, String password) {
  ssid.trim();
  if (ssid.length() == 0) return;

  WiFiProfile profiles[WIFI_PROFILE_MAX];
  int count = 0;
  count = appendWiFiProfile(profiles, count, ssid, password, true);

  prefs.begin("dotwatch", true);
  String stored = prefs.getString(WIFI_PROFILES_KEY, "");
  prefs.end();

  if (stored.length() > 0) {
    StaticJsonDocument<1536> doc;
    DeserializationError error = deserializeJson(doc, stored);
    if (!error && doc.is<JsonArray>()) {
      JsonArray arr = doc.as<JsonArray>();
      for (JsonObject item : arr) {
        if (count >= WIFI_PROFILE_MAX) break;
        String savedSsid = item["s"] | "";
        String savedPassword = item["p"] | "";
        count = appendWiFiProfile(profiles, count, savedSsid, savedPassword, false);
      }
    }
  }

  saveWiFiProfiles(profiles, count);
}

void persistConnectedWiFiProfile(const WiFiProfile &profile) {
  cfg.wifiSsid = profile.ssid;
  cfg.wifiPassword = profile.password;

  prefs.begin("dotwatch", false);
  prefs.putString("wifiSsid", cfg.wifiSsid);
  prefs.putString("wifiPass", cfg.wifiPassword);
  prefs.end();

  rememberWiFiProfile(cfg.wifiSsid, cfg.wifiPassword);
}

int knownWiFiProfileCount() {
  WiFiProfile profiles[WIFI_PROFILE_MAX];
  return loadWiFiProfiles(profiles, WIFI_PROFILE_MAX);
}

String knownWiFiProfileSummary() {
  WiFiProfile profiles[WIFI_PROFILE_MAX];
  int count = loadWiFiProfiles(profiles, WIFI_PROFILE_MAX);

  if (count == 0) return "None";

  String out;
  for (int i = 0; i < count; i++) {
    if (i > 0) out += ", ";
    out += profiles[i].ssid;
    if (profiles[i].primary) out += "*";
  }
  return out;
}

