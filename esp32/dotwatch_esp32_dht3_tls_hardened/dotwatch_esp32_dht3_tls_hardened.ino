void handleSave() {
  if (!requireAdmin()) return;

  Config next = cfg;
  String previousWifiSsid = cfg.wifiSsid;

  if (server.hasArg("wifiSsid")) next.wifiSsid = server.arg("wifiSsid");
  if (server.hasArg("wifiPassword") && server.arg("wifiPassword").length() > 0) next.wifiPassword = server.arg("wifiPassword");
  if (server.hasArg("apiUrl")) next.apiUrl = normalizeApiUrl(server.arg("apiUrl"));
  if (server.hasArg("tlsCaCert")) {
    String tlsInput = server.arg("tlsCaCert");
    tlsInput.trim();
    if (tlsInput == "CLEAR") {
      next.tlsCaCert = "";
    } else if (tlsInput.length() > 0) {
      next.tlsCaCert = server.arg("tlsCaCert");
    }
  }
  if (server.hasArg("deviceCode")) next.deviceCode = server.arg("deviceCode");
  if (server.hasArg("deviceSecret") && server.arg("deviceSecret").length() > 0) next.deviceSecret = server.arg("deviceSecret");
  if (server.hasArg("adminPin") && server.arg("adminPin").length() > 0) next.adminPin = server.arg("adminPin");
  if (server.hasArg("dhtPin")) next.dhtPin = server.arg("dhtPin").toInt();
  if (server.hasArg("dhtType")) next.dhtType = server.arg("dhtType").toInt() == 22 ? DHT22 : DHT11;
  if (server.hasArg("sendIntervalSec")) {
    int sendIntervalSec = server.arg("sendIntervalSec").toInt();
    if (sendIntervalSec < 10) sendIntervalSec = 10;
    next.sendIntervalMs = (unsigned long)sendIntervalSec * 1000UL;
  }
  if (server.hasArg("fallbackDummy")) next.fallbackDummy = server.arg("fallbackDummy") == "true";

  next.wifiSsid.trim();
  previousWifiSsid.trim();
  if (next.wifiSsid != previousWifiSsid && (!server.hasArg("wifiPassword") || server.arg("wifiPassword").length() == 0)) {
    next.wifiPassword = "";
  }
  next.apiUrl = normalizeApiUrl(next.apiUrl);
  next.deviceCode.trim();
  next.deviceSecret.trim();
  next.adminPin.trim();
  next.tlsCaCert.trim();
  if (next.adminPin.length() > 0 && next.adminPin.length() < 4) {
    String body = "<section class='card'><h2>Invalid PIN</h2><div class='notice'>Local Admin PIN ต้องมีอย่างน้อย 4 ตัวอักษร</div><div class='row'><a class='btn btn2' href='/'>Back</a></div></section>";
    server.send(400, "text/html; charset=utf-8", pageShell("Invalid PIN", body));
    return;
  }

  if (next.tlsCaCert.length() > 0 && next.tlsCaCert.indexOf("BEGIN CERTIFICATE") < 0) {
    String body = "<section class='card'><h2>Invalid Root CA</h2><div class='notice'>Root CA certificate format ไม่ถูกต้อง ต้องเป็น PEM ที่มี BEGIN CERTIFICATE หรือพิมพ์ CLEAR เพื่อลบ</div><div class='row'><a class='btn btn2' href='/'>Back</a></div></section>";
    server.send(400, "text/html; charset=utf-8", pageShell("Invalid Root CA", body));
    return;
  }

  saveConfig(next);
  rememberWiFiProfile(next.wifiSsid, next.wifiPassword);

  String body = "<section class='card'><h2>Saved</h2><p class='muted'>บันทึกแล้ว กำลัง restart ESP32 ภายใน 2 วินาที</p><a class='btn btn2' href='/'>Back</a></section>";
  server.send(200, "text/html; charset=utf-8", pageShell("Saved", body));
  delay(1500);
  ESP.restart();
}

void handleReset() {
  if (!requireAdmin()) return;

  clearConfig();
  String body = "<section class='card'><h2>Config Cleared</h2><p class='muted'>ล้างค่าแล้ว กำลัง restart เข้าสู่ setup AP ใหม่</p></section>";
  server.send(200, "text/html; charset=utf-8", pageShell("Reset", body));
  delay(1500);
  ESP.restart();
}

void setupWebRoutes() {
  server.on("/", HTTP_GET, handleRoot);
  server.on("/save", HTTP_POST, handleSave);
  server.on("/reset", HTTP_POST, handleReset);
  server.on("/json", HTTP_GET, handleJson);
  server.on("/test", HTTP_GET, handleTest);
  server.on("/generate_204", HTTP_GET, handleCaptive);
  server.on("/gen_204", HTTP_GET, handleCaptive);
  server.on("/hotspot-detect.html", HTTP_GET, handleCaptive);
  server.on("/fwlink", HTTP_GET, handleCaptive);
  server.onNotFound([]() {
    if (portalMode) {
      handleCaptive();
      return;
    }
    server.send(404, "text/plain; charset=utf-8", "Not found");
  });
}

void setupPortal() {
  portalMode = true;

  WiFi.mode(WIFI_AP_STA);
  WiFi.softAP(SETUP_AP_SSID, SETUP_AP_PASSWORD);

  IPAddress apIp = WiFi.softAPIP();
  dnsServer.start(DNS_PORT, "*", apIp);

  Serial.print("Setup AP started. SSID=");
  Serial.println(SETUP_AP_SSID);
  Serial.print("Setup URL: http://");
  Serial.println(apIp);

  setupWebRoutes();
  server.begin();
}

void setupLocalAdminPortal() {
  portalMode = false;

  setupWebRoutes();
  server.begin();

  Serial.print("Local Admin URL: http://");
  Serial.print(WiFi.localIP());
  Serial.println("/");
  Serial.println("Local Admin is PIN protected.");
  if (cfg.adminPin.length() == 0) {
    Serial.println("Default PIN: last 6 characters of Device Code. Set a custom PIN in the portal.");
  }
}

bool postIngest(float temperature, float humidity, int rssi) {
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("POST skipped: Wi-Fi not connected");
    recordSendFail(0, "Wi-Fi not connected");
    return false;
  }

  if (!hasRequiredConfig()) {
    Serial.println("POST skipped: config incomplete");
    recordSendFail(0, "config incomplete");
    return false;
  }

  String endpoint = cfg.apiUrl + "/api/ingest";

  StaticJsonDocument<512> doc;
  doc["firmwareVersion"] = FIRMWARE_VERSION;

  String timestamp = isoTimestampOrEmpty();
  if (timestamp.length() > 0) doc["timestamp"] = timestamp;

  JsonObject metrics = doc.createNestedObject("metrics");
  metrics["metric_1"] = roundf(temperature * 100.0f) / 100.0f;
  metrics["metric_2"] = roundf(humidity * 100.0f) / 100.0f;
  metrics["metric_3"] = rssi;

  String body;
  serializeJson(doc, body);

  HTTPClient http;
  WiFiClientSecure secureClient;
  WiFiClient plainClient;

  bool beginOk = false;
  if (endpoint.startsWith("https://")) {
    if (hasEffectiveTlsCaCert()) {
      secureClient.setCACert(effectiveTlsCaCert());
      Serial.print("TLS mode: Root CA verification enabled, source=");
      Serial.println(tlsCaCertSourceText());
    } else {
#if DOTWATCH_ALLOW_INSECURE_TLS_FALLBACK
      secureClient.setInsecure();
      Serial.println("TLS mode: insecure fallback enabled by build flag");
#else
      Serial.println("POST skipped: HTTPS Root CA is required in production firmware");
      recordSendFail(0, "HTTPS Root CA is required");
      return false;
#endif
    }
    beginOk = http.begin(secureClient, endpoint);
  } else {
    Serial.println("TLS mode: plain HTTP");
    beginOk = http.begin(plainClient, endpoint);
  }

  if (!beginOk) {
    Serial.println("HTTP begin failed");
    recordSendFail(0, "HTTP begin failed");
    return false;
  }

  http.setTimeout(15000);
  http.addHeader("Accept", "application/json");
  http.addHeader("Content-Type", "application/json");
  http.addHeader("User-Agent", "dotwatch-esp32-dht3/" FIRMWARE_VERSION);
  http.addHeader("x-device-code", cfg.deviceCode);
  http.addHeader("x-device-secret", cfg.deviceSecret);

  int status = http.POST(body);
  String response = http.getString();

  Serial.print("POST status=");
  Serial.println(status);
  Serial.print("payload=");
  Serial.println(body);
  if (response.length()) {
    Serial.print("response=");
    Serial.println(response);
  }

  http.end();

  if (status >= 200 && status < 300) {
    recordSendOk(status);
    return true;
  }

  recordSendFail(status, response.length() ? response : "HTTP error");
  return false;
}

void setup() {
  Serial.begin(115200);
  delay(500);
  randomSeed(esp_random());

  pinMode(STATUS_LED_PIN, OUTPUT);
  pinMode(RESET_BUTTON_PIN, INPUT_PULLUP);
  setLed(false);

  Serial.println();
  Serial.println("dotWatch ESP32-DHT3 Hardened Firmware");
  Serial.print("Firmware: ");
  Serial.println(FIRMWARE_VERSION);
  Serial.println("Additional model only. Does not replace Raspberry Pi / DW20CH.");
  Serial.print("Status LED GPIO: ");
  Serial.println(STATUS_LED_PIN);
  Serial.print("Reset button GPIO: ");
  Serial.println(RESET_BUTTON_PIN);

  loadConfig();
  setupDht();

  bool wifiOk = connectWiFi();
  if (wifiOk) setupTime();

  if (!hasRequiredConfig() || !wifiOk) {
    setupPortal();
  } else {
    WiFi.mode(WIFI_STA);
    Serial.println("Normal send mode. Config portal is not active.");
    Serial.print("Device Code: ");
    Serial.println(cfg.deviceCode);
    Serial.print("Device Secret: ");
    Serial.println(maskSecret(cfg.deviceSecret));
    Serial.print("TLS Mode: ");
    Serial.println(tlsModeText());
    setupLocalAdminPortal();
  }
}

void loop() {
  checkResetButton();
  checkSelfRecovery();
  updateStatusLed();

  if (!portalMode) {
    server.handleClient();
  }

  if (portalMode) {
    dnsServer.processNextRequest();
    server.handleClient();

    if (hasRequiredConfig() && WiFi.status() != WL_CONNECTED && millis() - lastWifiRetryAt > PORTAL_RETRY_WIFI_MS) {
      lastWifiRetryAt = millis();
      connectWiFi();
      if (WiFi.status() == WL_CONNECTED) setupTime();
    }

    delay(2);
    return;
  }

  if (WiFi.status() != WL_CONNECTED) {
    connectWiFi();
    delay(1000);
    return;
  }

  unsigned long now = millis();
  if (now - lastSendAt < cfg.sendIntervalMs) {
    delay(250);
    return;
  }
  lastSendAt = now;

  float temperature = NAN;
  float humidity = NAN;
  int rssi = 0;

  if (!readMetrics(temperature, humidity, rssi)) {
    Serial.println("DHT read failed. Not sending.");
    recordSendFail(0, "DHT read failed");
    return;
  }

  Serial.print("SENT metric_1=");
  Serial.print(temperature, 2);
  Serial.print(" metric_2=");
  Serial.print(humidity, 2);
  Serial.print(" metric_3=");
  Serial.println(rssi);

  bool ok = postIngest(temperature, humidity, rssi);
  Serial.println(ok ? "SERVER_OK" : "SERVER_ERROR");
}
