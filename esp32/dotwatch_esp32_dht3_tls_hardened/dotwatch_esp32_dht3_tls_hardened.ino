void handleCaptive() {
  server.sendHeader("Location", String("http://") + WiFi.softAPIP().toString() + "/", true);
  server.send(302, "text/plain", "");
}

void handleJson() {
  if (!portalMode && !isAdminAuthorized()) {
    StaticJsonDocument<512> publicDoc;
    publicDoc["firmwareVersion"] = FIRMWARE_VERSION;
    publicDoc["modelKey"] = "esp32_dht3";
    publicDoc["wifiConnected"] = WiFi.status() == WL_CONNECTED;
    publicDoc["ip"] = WiFi.status() == WL_CONNECTED ? WiFi.localIP().toString() : WiFi.softAPIP().toString();
    publicDoc["localAdminProtected"] = true;
    publicDoc["message"] = "Open / and enter Local Admin PIN for full config.";
    String publicOut;
    serializeJsonPretty(publicDoc, publicOut);
    server.send(200, "application/json; charset=utf-8", publicOut);
    return;
  }

  StaticJsonDocument<1536> doc;
  doc["firmwareVersion"] = FIRMWARE_VERSION;
  doc["modelKey"] = "esp32_dht3";
  doc["wifiConnected"] = WiFi.status() == WL_CONNECTED;
  doc["ip"] = WiFi.status() == WL_CONNECTED ? WiFi.localIP().toString() : WiFi.softAPIP().toString();
  doc["wifiSsid"] = WiFi.status() == WL_CONNECTED ? WiFi.SSID() : cfg.wifiSsid;
  doc["rememberedWifiProfiles"] = knownWiFiProfileCount();
  doc["apiUrl"] = cfg.apiUrl;
  doc["deviceCode"] = cfg.deviceCode;
  doc["deviceSecretMasked"] = maskSecret(cfg.deviceSecret);
  doc["adminPinSet"] = cfg.adminPin.length() >= 4;
  doc["tlsMode"] = tlsModeText();
  doc["tlsCaCertSet"] = hasEffectiveTlsCaCert();
  doc["tlsCaCertSource"] = tlsCaCertSourceText();
  doc["tlsPortalCaCertSet"] = hasTlsCaCert();
  doc["tlsEmbeddedCaCertSet"] = hasEmbeddedTlsCaCert();
  doc["dhtPin"] = cfg.dhtPin;
  doc["dhtType"] = cfg.dhtType == DHT22 ? "DHT22" : "DHT11";
  doc["sendIntervalSeconds"] = cfg.sendIntervalMs / 1000;
  doc["rssi"] = WiFi.status() == WL_CONNECTED ? WiFi.RSSI() : 0;
  doc["uptime"] = uptimeText();
  doc["lastSendStatus"] = lastSendStatus;
  doc["lastSendError"] = lastSendError;
  doc["lastHttpStatus"] = lastHttpStatus;
  doc["totalSendOk"] = totalSendOk;
  doc["totalSendFail"] = totalSendFail;
  doc["statusLedPin"] = STATUS_LED_PIN;
  doc["resetButtonPin"] = RESET_BUTTON_PIN;

  String out;
  serializeJsonPretty(doc, out);
  server.send(200, "application/json; charset=utf-8", out);
}

bool readMetrics(float &temperature, float &humidity, int &rssi) {
  if (dht == nullptr) setupDht();

  temperature = dht->readTemperature();
  humidity = dht->readHumidity();
  rssi = WiFi.status() == WL_CONNECTED ? WiFi.RSSI() : 0;

  if (!isnan(temperature) && !isnan(humidity)) return true;

  if (cfg.fallbackDummy) {
    temperature = 24.0 + random(0, 800) / 100.0;
    humidity = 45.0 + random(0, 2000) / 100.0;
    return true;
  }

  return false;
}

void handleTest() {
  if (!requireAdmin()) return;

  float temperature = NAN;
  float humidity = NAN;
  int rssi = 0;
  bool ok = readMetrics(temperature, humidity, rssi);

  String body = "<section class='card'><h2>Read Test</h2>";
  if (ok) {
