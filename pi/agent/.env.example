# dotWatch Raspberry Pi Agent Example
# Copy to /home/pi/dotwatch-pi-agent/.env on Raspberry Pi.
# Never commit the real DEVICE_SECRET or CONFIG_UI_PASSWORD.

DOTWATCH_API_URL=https://dotwatch-backend.onrender.com
DEVICE_CODE=DW-CHANGE-ME
DEVICE_SECRET=CHANGE_DEVICE_SECRET_HERE
SEND_INTERVAL_SECONDS=10
REQUEST_TIMEOUT_SECONDS=15
FIRMWARE_VERSION=rpi-agent-0.2.0

# Options: dummy, modbus, modbus_tcp, modbus_rtu
# - dummy: generated test metrics
# - modbus: use mode from modbus_config.json
# - modbus_tcp / modbus_rtu: force that mode from .env
SENSOR_SOURCE=dummy
MODBUS_CONFIG_PATH=/home/pi/dotwatch-pi-agent/modbus_config.json

# Offline queue keeps telemetry locally when network/backend is unavailable.
OFFLINE_QUEUE_ENABLED=true
OFFLINE_QUEUE_PATH=/home/pi/dotwatch-pi-agent/data/offline_queue.jsonl
OFFLINE_QUEUE_MAX_ITEMS=1000
QUEUE_FLUSH_LIMIT=20
QUEUE_FLUSH_BATCH_ENABLED=true
MAX_BACKOFF_SECONDS=60
LOG_METRICS=true

# Config UI login for Raspberry Pi setup page.
CONFIG_UI_USERNAME=admin
CONFIG_UI_PASSWORD=CHANGE_THIS_CONFIG_UI_PASSWORD
