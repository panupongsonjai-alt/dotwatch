# dotWatch Raspberry Pi Agent settings
# Copy this file to .env on the Raspberry Pi and fill real secrets there.
# Do NOT commit real DEVICE_SECRET or CONFIG_UI_PASSWORD.

DOTWATCH_API_URL=https://dotwatch-backend.onrender.com
# Keep false for production. Set true only for a trusted local/lab HTTP backend.
ALLOW_HTTP_API=false
DEVICE_CODE=DW-CHANGE-ME
DEVICE_SECRET=CHANGE_ME_DEVICE_SECRET
SEND_INTERVAL_SECONDS=20
REQUEST_TIMEOUT_SECONDS=15
FIRMWARE_VERSION=rpi-agent-0.2.0
SENSOR_SOURCE=dummy
MODBUS_CONFIG_PATH=/home/pi/dotwatch-pi-agent/modbus_config.json
OFFLINE_QUEUE_ENABLED=true
OFFLINE_QUEUE_PATH=/home/pi/dotwatch-pi-agent/data/offline_queue.jsonl
OFFLINE_QUEUE_MAX_ITEMS=1000
QUEUE_FLUSH_LIMIT=1
MAX_BACKOFF_SECONDS=60
LOG_METRICS=true
CONFIG_UI_USERNAME=admin
CONFIG_UI_PASSWORD=CHANGE_ME_CONFIG_UI_PASSWORD