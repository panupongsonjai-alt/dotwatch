# dotWatch Backend
PORT=4000
NODE_ENV=development

# PostgreSQL / TimescaleDB
DATABASE_URL=postgresql://dotwatch:dotwatch123@localhost:5432/dotwatch

# Comma-separated allowed dashboard origins
# Local example:
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
# Production example:
# CORS_ORIGIN=https://dotwatch.onrender.com

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Device ingest throttling
INGEST_MIN_INTERVAL_SECONDS=5
