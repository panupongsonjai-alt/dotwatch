# dotWatch Backend Environment Example

PORT=4000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dotwatch
CORS_ORIGIN=http://localhost:5173

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Required to store newly created/reset Device Secrets in encrypted form.
# Generate:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DEVICE_SECRET_ENCRYPTION_KEY=

INGEST_MIN_INTERVAL_SECONDS=5
