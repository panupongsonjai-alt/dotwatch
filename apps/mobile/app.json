{
  "expo": {
    "name": "dotWatch",
    "slug": "dotwatch-mobile",
    "version": "0.2.0",
    "orientation": "portrait",
    "scheme": "dotwatch",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.dotwatch.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0b1220"
      }
    },
    "ios": {
      "bundleIdentifier": "com.dotwatch.mobile",
      "supportsTablet": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4a67ad2a-98a6-47a7-85ae-316bcd864365"
      }
    },
    "owner": "panupongsonjai"
  }
}
