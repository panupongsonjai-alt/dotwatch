# dotWatch Admin - Local Development
# Copy this file to apps/admin/.env.local and fill Firebase values.

# Use Render backend for real admin data during local admin development.
VITE_API_URL=https://dotwatch-backend.onrender.com
VITE_USE_MOCK_ADMIN_API=false
VITE_ADMIN_REQUEST_TIMEOUT_MS=20000

# Firebase Web SDK config is required for Admin login.
# Get these from Firebase Console > Project settings > General > Web app > SDK setup and configuration.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
