# dotWatch Dashboard - Local Development Example
# Copy to apps/dashboard/.env.local for local development.

VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000
VITE_DEMO_MODE=false

# Performance / timeout settings
VITE_REQUEST_TIMEOUT_MS=20000
VITE_API_CACHE_TTL_MS=6000
VITE_API_SLOW_CACHE_TTL_MS=12000

# Firebase Web SDK config is required for Login/Register.
# These are public Firebase web config values, but still keep real values in .env.local only.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
