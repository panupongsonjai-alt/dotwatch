{
  "name": "dotwatch",
  "private": true,
  "version": "0.1.0",
  "description": "dotWatch IoT monitoring monorepo: dashboard, admin, mobile, backend, Raspberry Pi agent.",
  "scripts": {
    "install:all": "npm --prefix apps/dashboard install && npm --prefix apps/admin install && npm --prefix apps/mobile install && npm --prefix services/backend install",
    "dashboard:dev": "npm --prefix apps/dashboard run dev",
    "dashboard:build": "npm --prefix apps/dashboard run build",
    "admin:dev": "npm --prefix apps/admin run dev -- --port 5174",
    "admin:build": "npm --prefix apps/admin run build",
    "mobile:start": "npm --prefix apps/mobile run start",
    "mobile:android": "npm --prefix apps/mobile run android",
    "mobile:ios": "npm --prefix apps/mobile run ios",
    "mobile:typecheck": "npm --prefix apps/mobile run typecheck",
    "backend:dev": "npm --prefix services/backend run dev",
    "backend:start": "npm --prefix services/backend run start",
    "backend:migrate": "npm --prefix services/backend run migrate",
    "check:dashboard": "npm --prefix apps/dashboard run build",
    "check:admin": "npm --prefix apps/admin run build",
    "check:mobile": "npm --prefix apps/mobile run typecheck",
    "check:backend": "node --check services/backend/src/server.js && node --check services/backend/src/config/env.js && node --check services/backend/src/utils/health.js && node --check services/backend/src/middlewares/requestContext.js && node --check services/backend/src/middlewares/authDevice.js && node --check services/backend/src/middlewares/deviceIngestRateLimit.js && node --check services/backend/src/security/fixedWindowLimiter.js",
    "check:all": "npm run check:backend && npm run check:dashboard && npm run check:admin && npm run check:mobile",
    "env:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-local-env.ps1",
    "env:prod:check": "node scripts/check-production-env.mjs",
    "doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/doctor.ps1",
    "scan:secrets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/scan-sensitive-files.ps1",
    "export:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/export-clean.ps1",
    "verify:phase1": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase1-verify.ps1",
    "smoke:backend": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backend-smoke-test.ps1",
    "verify:phase2": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase2-verify.ps1",
    "verify:phase3": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase3-verify.ps1",
    "audit:dashboard-style": "node scripts/dashboard-style-audit.mjs",
    "verify:phase4": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase4-verify.ps1",
    "report:backend-performance": "node services/backend/scripts/phase4-performance-report.mjs",
    "smoke:ingest-batch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backend-ingest-batch-test.ps1",
    "verify:phase5": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase5-verify.ps1",
    "report:commercial": "node services/backend/scripts/phase5-commercial-report.mjs",
    "check:render": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/render-health-check.ps1",
    "check:pi": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pi-agent-health-check.ps1",
    "diagnose:pi": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pi-ingest-diagnostic.ps1",
    "diagnose:backend500": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backend-500-diagnostic.ps1",
    "check:pi:ingest": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pi-ingest-diagnostic.ps1",
    "check:backend500": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backend-500-diagnostic.ps1",
    "backend:prod:check": "npm --prefix services/backend run check:prod-env",
    "verify:phase2:security": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase2-security-verify.ps1",
    "db:preflight": "npm --prefix services/backend run db:preflight",
    "db:health": "npm --prefix services/backend run db:health",
    "db:backup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db-backup.ps1",
    "db:restore": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db-restore.ps1",
    "db:repair-latest": "npm --prefix services/backend run db:repair-latest",
    "verify:phase3:db": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase3-db-verify.ps1",
    "verify:phase4:device": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase4-device-verify.ps1",
    "check:esp32:field": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/esp32-field-check.ps1",
    "verify:esp32:product": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase12a-esp32-product-verify.ps1",
    "check:pi:field": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pi-field-commissioning.ps1",
    "ops:health": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ops-health-check.ps1",
    "ops:release-check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ops-release-check.ps1",
    "ops:backend-report": "npm --prefix services/backend run ops:report",
    "verify:phase6:ops": "node scripts/phase6-ops-verify.mjs",
    "report:tenant": "npm --prefix services/backend run tenant:report",
    "verify:phase7:tenant": "node scripts/phase7-tenant-verify.mjs",
    "db:env:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db-env-check.ps1",
    "verify:phase7d:dbops": "node scripts/phase7d-dbops-verify.mjs",
    "verify:phase8:release": "node scripts/phase8-production-verify.mjs",
    "release:render": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase8-render-release.ps1",
    "db:parity": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase9-db-parity-check.ps1",
    "security:rotation:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase9-security-rotation-check.ps1",
    "verify:phase9:maintenance": "node scripts/phase9-maintenance-verify.mjs",
    "db:parity:core": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase9-core-parity-check.ps1",
    "verify:phase9c:core-parity": "node scripts/phase9c-core-parity-verify.mjs",
    "verify:phase9d:core-parity": "node scripts/phase9d-core-parity-verify.mjs",
    "db:parity:compat": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase9-core-compatibility-check.ps1",
    "verify:phase9e:compat-parity": "node scripts/phase9e-compat-parity-verify.mjs",
    "verify:phase9f:nullability": "node scripts/phase9f-nullability-verify.mjs",
    "verify:phase10e:dashboard-auth": "node scripts/phase10e-dashboard-auth-env-verify.mjs",
    "verify:phase11d:admin-sidebar": "node scripts/phase11d-admin-sidebar-parity-verify.mjs",
    "verify:phase11g:admin-dashboard-parity": "node scripts/phase11g-admin-dashboard-parity-verify.mjs",
    "verify:phase11h:dashboard-sidebar-vertical": "node scripts/phase11h-dashboard-sidebar-vertical-verify.mjs",
    "verify:phase11i:admin-dashboard-comfort": "node scripts/phase11i-admin-dashboard-comfort-verify.mjs",
    "verify:phase11j:dashboard-sidebar-spacing": "node scripts/phase11j-dashboard-sidebar-admin-spacing-verify.mjs",
    "verify:phase-s1:security": "node scripts/verify-phase-s1-security.mjs",
    "test:phase-s1:prod-env": "node scripts/test-phase-s1-production-env.mjs",
    "verify:phase-s2:security": "node scripts/verify-phase-s2-security.mjs",
    "test:phase-s2:limiters": "node scripts/test-phase-s2-rate-limiters.mjs",
    "test:phase-s2:ota": "node scripts/test-phase-s2-ota-security.mjs",
    "test:phase-s2": "npm run verify:phase-s2:security && npm run test:phase-s2:limiters && npm run test:phase-s2:ota",
    "ota:key:generate": "npm --prefix services/ota-server run key:generate --",
    "ota:manifest:sign": "npm --prefix services/ota-server run manifest:sign --",
    "ota:publish:esp32": "npm --prefix services/ota-server run publish:esp32 --",
    "verify:phase-s3a:security": "node scripts/verify-phase-s3a-security.mjs",
    "test:phase-s3a:signing": "node scripts/test-phase-s3a-signing.mjs",
    "test:phase-s3a:ota": "node scripts/test-phase-s3a-ota-server.mjs",
    "test:phase-s3a": "npm run verify:phase-s3a:security && npm run test:phase-s3a:signing && npm run test:phase-s3a:ota"
  },
  "engines": {
    "node": ">=20"
  }
}
