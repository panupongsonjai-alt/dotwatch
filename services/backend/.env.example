# dotWatch Backend - Local Development Example
# Copy to services/backend/.env for local development only.
# Do not put real production secrets in this file.

PORT=4000
NODE_ENV=development

# Local PostgreSQL/TimescaleDB from docker-compose.yml
DATABASE_URL=postgres://dotwatch:dotwatch123@localhost:5432/dotwatch

# Local dashboard/admin dev servers
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Local development helper only.
# IMPORTANT: Production must set DEV_AUTH_BYPASS=false or omit it.
DEV_AUTH_BYPASS=true
DEV_AUTH_UID=local-dev-user
DEV_AUTH_EMAIL=local-dev@dotwatch.local

# Firebase Admin is optional when DEV_AUTH_BYPASS=true.
# For production, set real values in Render environment variables, not here.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Local-only key for encrypting stored device secrets.
# Generate your own value when needed:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DEVICE_SECRET_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Ingest and health timing
INGEST_MIN_INTERVAL_SECONDS=5
INGEST_MAX_METRICS_PER_READING=64
INGEST_BATCH_MAX_READINGS=120
DEVICE_WARNING_AFTER_SECONDS=30
DEVICE_OFFLINE_AFTER_SECONDS=60
DEVICE_STATUS_CHECK_SECONDS=30
HEALTH_DB_TIMEOUT_MS=3000
SHUTDOWN_TIMEOUT_MS=10000

# API safety limits
API_RATE_LIMIT_PER_MINUTE=600
INGEST_RATE_LIMIT_PER_MINUTE=50000
JSON_BODY_LIMIT=128kb
WS_SUBSCRIBE_TIMEOUT_MS=15000
WS_MAX_CLIENTS_PER_USER=5

# History performance / chart query strategy
HISTORY_RAW_MAX_HOURS=36
HISTORY_MAX_ROWS=5000
HISTORY_USE_CONTINUOUS_AGGREGATES=true
