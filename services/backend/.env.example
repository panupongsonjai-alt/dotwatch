# dotWatch Backend - Local Development Example
# Copy to services/backend/.env for local development only.
# Do not put real production secrets in this file.

PORT=4000
NODE_ENV=development

# Local PostgreSQL/TimescaleDB from docker-compose.yml
DATABASE_URL=postgres://dotwatch:dotwatch123@localhost:5432/dotwatch
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_SSL_DISABLED=false

# Local dashboard/admin dev servers
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Local development helper only.
# IMPORTANT: Production must set DEV_AUTH_BYPASS=false or omit it.
DEV_AUTH_BYPASS=true
DEV_AUTH_UID=local-dev-user
DEV_AUTH_EMAIL=local-dev@dotwatch.local

# Firebase Admin is optional when DEV_AUTH_BYPASS=true.
# For production, set real values in Render environment variables, not here.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Alarm notifications (optional). LINE uses Messaging API, not LINE Notify.
LINE_CHANNEL_ACCESS_TOKEN=
RESEND_API_KEY=
EMAIL_FROM=dotWatch Alerts <alerts@example.com>
NOTIFICATION_TIMEOUT_MS=10000

# Local-only key for encrypting stored device secrets.
# Generate your own value when needed:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Leave blank until you generate a unique local key. Never copy a committed key.
DEVICE_SECRET_ENCRYPTION_KEY=

# Ingest and health timing
INGEST_MIN_INTERVAL_SECONDS=5
INGEST_MAX_METRICS_PER_READING=64
INGEST_BATCH_MAX_READINGS=120
DEVICE_WARNING_AFTER_SECONDS=30
DEVICE_OFFLINE_AFTER_SECONDS=60
DEVICE_STATUS_CHECK_SECONDS=30
HEALTH_DB_TIMEOUT_MS=3000
SHUTDOWN_TIMEOUT_MS=10000

# API safety limits
API_RATE_LIMIT_PER_MINUTE=600
INGEST_RATE_LIMIT_PER_MINUTE=12000
INGEST_DEVICE_RATE_LIMIT_PER_MINUTE=180
DEVICE_AUTH_FAILURE_WINDOW_MS=300000
DEVICE_AUTH_MAX_FAILURES_PER_IP=30
DEVICE_AUTH_MAX_FAILURES_PER_DEVICE=10
DEVICE_AUTH_FAILURE_TRACKER_MAX_ENTRIES=10000
JSON_BODY_LIMIT=128kb
WS_PATH=/
WS_SUBSCRIBE_TIMEOUT_MS=15000
WS_MAX_PAYLOAD_BYTES=16384
WS_MAX_TOTAL_CLIENTS=2000
WS_MAX_CLIENTS_PER_IP=20
WS_MAX_UNAUTHENTICATED_CLIENTS_PER_IP=5
WS_MAX_CLIENTS_PER_USER=5
WS_MESSAGE_RATE_WINDOW_MS=10000
WS_MAX_MESSAGES_PER_WINDOW=30
WS_MAX_BUFFERED_BYTES=1048576

# History performance / chart query strategy
HISTORY_RAW_MAX_HOURS=36
HISTORY_MAX_ROWS=5000
HISTORY_USE_CONTINUOUS_AGGREGATES=true
# Observability / operations
LOG_LEVEL=debug
HTTP_LOG_ENABLED=true
SLOW_REQUEST_MS=1000
OPS_SUMMARY_INTERVAL_SECONDS=0
RELEASE_VERSION=local-dev

# Backend Weather API Virtual Device (Open-Meteo)
# Set true to let this backend poll virtual dot-WT-W1 virtual devices.
WEATHER_VIRTUAL_DEVICE_ENABLED=false
WEATHER_SCHEDULER_ENABLED=true
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEATHER_POLL_SECRET=
WEATHER_SCHEDULER_TICK_SECONDS=60
WEATHER_SCHEDULER_INITIAL_DELAY_MS=5000
WEATHER_FETCH_TIMEOUT_MS=10000
WEATHER_POLL_BATCH_SIZE=25
WEATHER_POLL_CONCURRENCY=4
