# dotWatch Backend - Production Environment Example
# Configure these values in Render Environment Variables or copy locally to .env.production for checks only.
# Do not commit real secrets.

NODE_ENV=production
PORT=4000

# Render/Postgres connection string. Keep empty in committed examples.
DATABASE_URL=
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_SSL_DISABLED=false
# Optional PEM CA bundle when your database provider uses a private CA.
DATABASE_SSL_CA=

# Comma-separated allowed frontend origins.
# Production domains must use HTTPS.
# To let a local dashboard call this production backend, explicitly enable the flag
# and add only the exact loopback origins that you use.
ALLOW_LOCAL_CORS_IN_PRODUCTION=false
CORS_ORIGIN=https://dotwatch.onrender.com,https://dotwatch-admin.onrender.com
# Example for temporary local dashboard access:
# ALLOW_LOCAL_CORS_IN_PRODUCTION=true
# CORS_ORIGIN=https://dotwatch.onrender.com,https://dotwatch-admin.onrender.com,http://localhost:5173,http://127.0.0.1:5173

# Firebase Admin SDK values. Keep private values in Render Environment Variables only.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=PASTE_ESCAPED_FIREBASE_PRIVATE_KEY_VALUE_IN_RENDER_ONLY
# Required for encrypted device secret storage.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DEVICE_SECRET_ENCRYPTION_KEY=

# Never enable this in production.
DEV_AUTH_BYPASS=false

# Device status timing
DEVICE_WARNING_AFTER_SECONDS=30
DEVICE_OFFLINE_AFTER_SECONDS=60
DEVICE_STATUS_CHECK_SECONDS=30

# API safety limits
API_RATE_LIMIT_PER_MINUTE=600
INGEST_RATE_LIMIT_PER_MINUTE=12000
INGEST_DEVICE_RATE_LIMIT_PER_MINUTE=180
DEVICE_AUTH_FAILURE_WINDOW_MS=300000
DEVICE_AUTH_MAX_FAILURES_PER_IP=30
DEVICE_AUTH_MAX_FAILURES_PER_DEVICE=10
DEVICE_AUTH_FAILURE_TRACKER_MAX_ENTRIES=10000
JSON_BODY_LIMIT=128kb
WS_PATH=/
WS_SUBSCRIBE_TIMEOUT_MS=15000
WS_MAX_PAYLOAD_BYTES=16384
WS_MAX_TOTAL_CLIENTS=2000
WS_MAX_CLIENTS_PER_IP=20
WS_MAX_UNAUTHENTICATED_CLIENTS_PER_IP=5
WS_MAX_CLIENTS_PER_USER=5
WS_MESSAGE_RATE_WINDOW_MS=10000
WS_MAX_MESSAGES_PER_WINDOW=30
WS_MAX_BUFFERED_BYTES=1048576

# Health/performance
HEALTH_DB_TIMEOUT_MS=3000
SHUTDOWN_TIMEOUT_MS=10000
HISTORY_RAW_MAX_HOURS=36
HISTORY_MAX_ROWS=5000
HISTORY_USE_CONTINUOUS_AGGREGATES=true
INGEST_MAX_METRICS_PER_READING=64
INGEST_BATCH_MAX_READINGS=120
INGEST_MIN_INTERVAL_SECONDS=5
# Observability / operations
LOG_LEVEL=info
HTTP_LOG_ENABLED=true
SLOW_REQUEST_MS=1500
# 0 = disabled. Use 300 or 600 if you want periodic operational heartbeat logs.
OPS_SUMMARY_INTERVAL_SECONDS=0
# Optional release label. Render also exposes RENDER_GIT_COMMIT when connected to Git.
RELEASE_VERSION=

# Backend Weather API Virtual Device (Open-Meteo)
# Set true to let this backend poll virtual Weather API Demo devices.
WEATHER_VIRTUAL_DEVICE_ENABLED=false
WEATHER_SCHEDULER_ENABLED=true
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEATHER_POLL_SECRET=
WEATHER_SCHEDULER_TICK_SECONDS=60
WEATHER_SCHEDULER_INITIAL_DELAY_MS=5000
WEATHER_FETCH_TIMEOUT_MS=10000
WEATHER_POLL_BATCH_SIZE=25
WEATHER_POLL_CONCURRENCY=4
