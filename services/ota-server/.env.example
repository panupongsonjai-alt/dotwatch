NODE_ENV=development
PORT=4100
PUBLIC_BASE_URL=https://dotwatch-ota.onrender.com

# Production must keep both settings below.
OTA_ALLOW_UNREGISTERED_DEVICES=false
OTA_REQUIRE_DEVICE_SCOPE=true

# Phase S3A firmware trust chain. Production must enforce signed releases.
OTA_REQUIRE_SIGNED_RELEASES=true
OTA_RELEASE_KEY_ID=dotwatch-release-2026-01
OTA_RELEASE_PUBLIC_KEY_FILE=keys/release-signing.public.pem
# Optional but recommended: pin the generated public-key fingerprint.
OTA_RELEASE_PUBLIC_KEY_SHA256=
# Private key is used only by the local release publisher, never by Render.
OTA_SIGNING_PRIVATE_KEY_FILE=

# Preferred format: each device is bound to allowed model keys and channels.
# Keep real values only in Render Environment Variables.
OTA_DEVICE_REGISTRY_JSON={"DW-EXAMPLE":{"secret":"replace-with-device-secret","modelKeys":["esp32_dht3"],"channels":["stable"]}}

# Deprecated compatibility input. Production startup is rejected when scope is
# required but a legacy entry has no modelKeys/channels.
OTA_DEVICE_SECRETS_JSON={}

OTA_MAX_BODY_BYTES=16384
OTA_RATE_LIMIT_WINDOW_MS=60000
OTA_RATE_LIMIT_PER_IP=120
OTA_RATE_LIMIT_PER_DEVICE=60
OTA_AUTH_FAILURE_LIMIT_PER_IP=20
OTA_AUTH_FAILURE_LIMIT_PER_DEVICE=10
OTA_RATE_LIMIT_MAX_ENTRIES=10000
