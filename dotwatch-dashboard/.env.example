# dotWatch Dashboard Environment Example
# Copy this file to .env.local for local development.
# Do not commit real .env files.

VITE_API_URL=http://localhost:4000

# Default API timeout.
# Recommended: 45000 because Render cold start or heavy Alarm queries may take longer than 15 seconds.
VITE_REQUEST_TIMEOUT_MS=45000

# Firebase Web SDK config
# These are public client identifiers, but should still be managed carefully.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
