# dotWatch Dashboard Environment Example
# Copy to .env.local for local development.

VITE_API_URL=http://localhost:4000

# Faster UI defaults.
# Render cold start may still need 20 seconds, but the dashboard now caches GET requests.
VITE_REQUEST_TIMEOUT_MS=20000
VITE_API_CACHE_TTL_MS=6000
VITE_API_SLOW_CACHE_TTL_MS=12000

# Firebase Web SDK config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
